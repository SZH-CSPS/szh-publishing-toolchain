# Toolchain SZH/CSPS pour la chaîne .md -> Pandoc -> WeasyPrint -> PDF.
# Construit un rootfs Debian reproductible, exporté en .tar puis importé via `wsl --import`.
# Le MÊME Containerfile servira de base bootc à la future migration Silverblue.
#
# Build : voir build-rootfs.sh (passe les --build-arg).

ARG DEBIAN_TAG=13-slim
FROM debian:${DEBIAN_TAG}

# --- Paramètres (surchageables au build) ---
ARG PANDOC_VERSION=3.5
ARG WEASYPRINT_VERSION=69.0
ARG FONTS="fonts-noto fonts-dejavu"
ARG DISTRO_VERSION=0.0.0-dev
ARG WSL_USER=redac

ENV DEBIAN_FRONTEND=noninteractive

# --- Dépendances système : Pango + fontconfig (WeasyPrint), make, python, curl ---
RUN apt-get update && apt-get install -y --no-install-recommends \
        make curl ca-certificates \
        python3 python3-venv \
        libpango-1.0-0 libpangoft2-1.0-0 libharfbuzz0b libffi8 fontconfig \
        ${FONTS} \
    && rm -rf /var/lib/apt/lists/*

# --- WeasyPrint épinglé dans un venv isolé (rendu reproductible) ---
RUN python3 -m venv /opt/weasyprint \
    && /opt/weasyprint/bin/pip install --no-cache-dir "weasyprint==${WEASYPRINT_VERSION}" \
    && ln -s /opt/weasyprint/bin/weasyprint /usr/local/bin/weasyprint

# --- Pandoc : binaire statique, version épinglée ---
RUN curl -fsSL "https://github.com/jgm/pandoc/releases/download/${PANDOC_VERSION}/pandoc-${PANDOC_VERSION}-1-amd64.deb" \
        -o /tmp/pandoc.deb \
    && dpkg -i /tmp/pandoc.deb \
    && rm /tmp/pandoc.deb

# --- Utilisateur par défaut (imported distro lit /etc/wsl.conf [user] default) ---
RUN useradd -m -s /bin/bash "${WSL_USER}"

# --- Config WSL + marqueur de version (idempotence du déploiement) ---
COPY wsl.conf /etc/wsl.conf
RUN echo "${DISTRO_VERSION}" > /etc/szh-publishing-version

# --- Polices supplémentaires de la revue : déposer ici puis fc-cache ---
# COPY fonts/ /usr/local/share/fonts/szh/
RUN fc-cache -f

# Vérification au build (échoue si la toolchain est cassée)
RUN pandoc --version | head -n1 && weasyprint --info | head -n1
