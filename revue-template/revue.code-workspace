{
  // Espace de travail d'une revue. Le rédacteur ouvre CE fichier (raccourci bureau).
  "folders": [ { "path": "." } ],
  "settings": {
    // Réglages spécifiques au projet (l'épuration de l'UI est au niveau utilisateur)
    "files.associations": { "*.md": "markdown" },
    "search.exclude": { "out/**": true }
  },
  "extensions": {
    "recommendations": [
      "tomoki1207.pdf",
      "Gruntfuggly.triggertaskonsave",
      "streetsidesoftware.code-spell-checker"
    ]
  }
}
