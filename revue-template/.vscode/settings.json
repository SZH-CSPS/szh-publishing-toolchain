{
  // Rebuild automatique à chaque sauvegarde de .md / .css / dossier.yaml
  "triggerTaskOnSave.tasks": {
    "Aperçu / Export PDF": ["**/*.md", "**/*.css", "dossier.yaml"]
  },
  "triggerTaskOnSave.restart": true,        // sauvegardes rapprochées -> on relance (debounce)
  "triggerTaskOnSave.showStatusBarToggle": true,

  "search.exclude": { "out/**": true },
  "files.watcherExclude": { "**/out/**": true, "**/*.tmp": true }
}
