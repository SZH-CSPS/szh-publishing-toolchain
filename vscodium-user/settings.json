{
  // ============ Interface épurée (« 0 technique ») ============
  "workbench.activityBar.location": "hidden",
  "workbench.statusBar.visible": true,
  "workbench.editor.showTabs": "single",
  "workbench.layoutControl.enabled": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.editor.editorActionsLocation": "hidden",
  "window.commandCenter": false,
  "window.menuBarVisibility": "compact",
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  "editor.lineNumbers": "off",
  "editor.glyphMargin": false,
  "editor.folding": false,
  "editor.guides.indentation": false,
  "editor.renderWhitespace": "none",
  "editor.overviewRulerBorder": false,
  "scm.diffDecorations": "none",

  // ============ Confort de rédaction ============
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 90,
  "editor.fontSize": 15,
  "editor.lineHeight": 1.7,
  "editor.cursorBlinking": "smooth",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": false,

  // Pas de bruit « développeur »… SAUF en Markdown, où les suggestions servent aux
  // blocs de style ::: (snippets, voir snippets/markdown.json). Réglage global = muet,
  // override [markdown] = suggestions actives (D15).
  "markdown.validate.enabled": false,
  "editor.quickSuggestions": { "other": false, "comments": false, "strings": false },
  "editor.suggestOnTriggerCharacters": false,
  "editor.parameterHints.enabled": false,
  "[markdown]": {
    "editor.quickSuggestions": { "other": true, "comments": false, "strings": false },
    "editor.suggestOnTriggerCharacters": true,
    "editor.wordBasedSuggestions": "off"
  },

  // ============ Build automatique à la sauvegarde ============
  // Régénère out/<article>/ (via la tâche « Aperçu / Export PDF » = make all) à chaque
  // sauvegarde de contenu. Tâche définie au niveau utilisateur (tasks.json).
  "triggerTaskOnSave.tasks": {
    "Aperçu / Export PDF": ["**/*.md", "**/*.css", "**/ausgabe.yaml"]
  },
  "triggerTaskOnSave.restart": true,           // sauvegardes rapprochées -> on relance (debounce)
  "triggerTaskOnSave.showStatusBarToggle": true,
  "task.allowAutomaticTasks": "on",

  "search.exclude": { "**/out/**": true, "**/media/**": true, "**/_convertis/**": true },
  // ⚠ NE JAMAIS ajouter "**/out/**" à files.watcherExclude : cela étoufferait les
  // événements de modification des PDF et l'aperçu cesserait de se rafraîchir
  // (cause de la panne historique — leçon V4/T6.1, PLANIFICATION.md).
  "files.watcherExclude": { "**/media/**": true, "**/*.tmp": true, "**/~$*": true },

  // ============ Masquage de fichiers dans l'explorateur (réserve, §6) ============
  // Le dossier de revue est déjà quasi vide de technique. Ajouter ici tout résidu
  // à cacher au rédacteur (le fichier reste sur le disque, il est juste masqué).
  "files.exclude": {
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/~$*": true,
    "**/*.lnk": true,
    "**/media/conversion-stats.json": true,
    "**/media/rapport.json": true,
    "**/media/refs-brutes.txt": true
  },

  // ============ Correction orthographique FR / DE / EN ============
  // Un mot est accepté s'il est valide dans AU MOINS une de ces langues (moins de faux
  // positifs en contexte bilingue). Bascule par suffixe de fichier via cSpell.overrides.
  "cSpell.language": "fr,de,en",
  "cSpell.enableFiletypes": ["markdown"],
  "cSpell.words": ["CSPS", "SZH", "WeasyPrint", "Pandoc"],
  "cSpell.overrides": [
    { "filename": "**/*.de.md", "language": "de" },
    { "filename": "**/*.fr.md", "language": "fr" },
    { "filename": "**/*.en.md", "language": "en" }
  ],

  // ============ Sécurité / déploiement flotte ============
  // Machine dédiée + contenu connu : on évite la pop-up de confiance (sinon le build
  // auto à la sauvegarde serait bloqué et le rédacteur perdu). Compromis assumé.
  "security.workspace.trust.enabled": false,

  // Extensions : pas de mise à jour live (VSIX vendorisés -> anti-GlassWorm)
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  "extensions.ignoreRecommendations": true,
  "update.mode": "manual",
  "update.showReleaseNotes": false,
  "telemetry.telemetryLevel": "off",

  // ============ Langue de l'interface ============
  // Défaut : anglais (seule option à jour et propre sur VSCodium).
  // Pour passer au FR figé (mai 2021) : vendoriser MS-CEINTL.vscode-language-pack-fr
  // et mettre "locale": "fr" dans %APPDATA%\VSCodium\argv.json.

  // ============ Aperçu PDF ============
  // Reload auto natif de tomoki1207.pdf — si capricieux, voir keybindings (Ctrl+Alt+R).
  "editor.acceptSuggestionOnEnter": "smart"
}
